# ============================================
# Vercel Serverless Environment Variables
# (Устанавливаются через Vercel Dashboard или CLI)
# ============================================

# Supabase Service Role Key (ОБЯЗАТЕЛЬНО для API)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# DeepSeek API Configuration (ОБЯЗАТЕЛЬНО для AI функций)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# Rate Limiting (ОПЦИОНАЛЬНО)
# {"note":"Не подтверждено","verification":"low"} - значение не указано в research_payload
RATE_LIMIT_PER_HOUR=60

# Cache TTL (ОПЦИОНАЛЬНО, по умолчанию из rag_policy: 72 часа)
CACHE_TTL_HOURS=72