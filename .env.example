# file: .env.example
# Client-side variables
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_SINGLE_USER_ID=YOUR_SUPABASE_USER_ID
VITE_AI_PROXY_URL=https://your-app.vercel.app/api/ai/proxy
VITE_AI_SUGGEST_URL=https://your-app.vercel.app/api/ai/suggest
VITE_TOOLS_API_URL=https://your-app.vercel.app/api/tools
VITE_ENV=development

# Server-side variables (Vercel Functions only)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# Optional AI limits/config
RATE_LIMIT_PER_HOUR=60
CACHE_TTL_HOURS=72
